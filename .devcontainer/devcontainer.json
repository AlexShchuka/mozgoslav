{
  "name": "mozgoslav",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/dotnet:2": { "version": "10.0" },
    "ghcr.io/devcontainers/features/node:1": { "version": "24" },
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/common-utils:2": { "installZsh": "true", "configureZshAsDefaultShell": "false" }
  },
  "postCreateCommand": "sudo apt-get update -qq && sudo apt-get install -y ffmpeg file && pip install --user 'uncomment==3.0.2' && npm install -g plop@4 && npm install -g lefthook@1",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "styled-components.vscode-styled-components",
        "ms-python.python",
        "ms-python.black-formatter",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode",
  "mounts": [],
  "workspaceFolder": "/workspaces/mozgoslav"
}
