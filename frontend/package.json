{
  "name": "mozgoslav",
  "version": "0.1.0",
  "private": true,
  "description": "Mozgoslav — local desktop second brain for conversations",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"electron/**/*.ts\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "plop": "plop",
    "build:helper:mac": "swift build -c release --package-path ../native/MozgoslavDictationHelper && chmod +x ../native/MozgoslavDictationHelper/.build/arm64-apple-macosx/release/mozgoslav-dictation-helper",
    "dist:mac": "bash ../scripts/fetch-bundle-models.sh && bash ../scripts/publish-backend-osx.sh && npm run build && npm run build:helper:mac && electron-builder --mac",
    "knip": "knip",
    "check-styles": "stylelint \"src/**/*.{ts,tsx}\"",
    "check-translations": "node scripts/check-translations.mjs",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch"
  },
  "dependencies": {
    "axios": "1.15.2",
    "framer-motion": "12.38.0",
    "graphql": "16.13.2",
    "graphql-request": "7.4.0",
    "graphql-ws": "6.0.8",
    "i18next": "26.0.7",
    "kbar": "0.1.0-beta.48",
    "lucide-react": "1.9.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-dropzone": "15.0.0",
    "react-hotkeys-hook": "5.2.4",
    "react-i18next": "17.0.4",
    "react-markdown": "10.1.0",
    "react-redux": "9.2.0",
    "react-router-dom": "7.14.2",
    "react-toastify": "11.1.0",
    "redux": "5.0.1",
    "redux-saga": "1.4.2",
    "remark-gfm": "4.0.1",
    "reselect": "5.1.1",
    "styled-components": "6.4.1",
    "uiohook-napi": "1.5.5"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/js": "9.39.4",
    "@graphql-codegen/cli": "6.3.1",
    "@graphql-codegen/client-preset": "5.3.0",
    "@parcel/watcher": "2.5.6",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "eslint": "9.39.4",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "identity-obj-proxy": "3.0.0",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "knip": "6.6.2",
    "plop": "4.0.5",
    "postcss-styled-syntax": "0.7.1",
    "prettier": "3.8.3",
    "redux-saga-test-plan": "4.0.6",
    "stylelint": "17.9.0",
    "stylelint-config-standard": "40.0.0",
    "ts-jest": "29.4.9",
    "typescript": "6.0.3",
    "vite": "7.3.2",
    "vite-plugin-electron": "0.29.1",
    "vite-plugin-electron-renderer": "0.14.6"
  }
}
