{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/main.tsx",
    "electron/main.ts",
    "electron/preload.ts",
    "__tests__/**/*.test.{ts,tsx}",
    "src/**/*.test.{ts,tsx}"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "electron/**/*.ts"
  ],
  "ignore": [
    "dist/**",
    "dist-electron/**",
    "release/**"
  ],
  "ignoreBinaries": [
    "swift"
  ]
}
